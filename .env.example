# Copy to ".env" and paste your Google OAuth Web client ID.
# Without this, the app still works fully on-device — only Google Sheets sync is disabled.
VITE_GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Comma-separated list of valid Etsy purchase codes. A buyer enters one of
# these in Settings to unlock "Connect Google Sheets" and start with a blank
# planner. This is a soft, client-side check (baked into the built JS, not a
# server-verified license) — it's a UX gate to keep casual visitors on the
# demo, not real anti-piracy protection.
VITE_ACCESS_CODES=CODE-ONE,CODE-TWO,CODE-THREE
